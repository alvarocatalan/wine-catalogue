---
import '../styles/global.css';
// Preload the primary Playfair weight (used by the hero + card/detail names).
// `?url` yields the hashed, base-correct URL so preload matches the @font-face
// Vite emits — works under both the dev root and the prod /wine-catalogue/ base.
import playfairPrimary from '../assets/fonts/playfair-display-latin-500-normal.woff2?url';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Catálogo de vinos',
  description = 'Catálogo de vinos con búsqueda y filtros por bodega, denominación de origen y añada.',
} = Astro.props;
// public/ is served under import.meta.env.BASE_URL: root in dev, /wine-catalogue/ in prod.
// All icon/manifest hrefs are prefixed with `base` so they resolve in both.
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="preload" href={playfairPrimary} as="font" type="font/woff2" crossorigin />
    <link rel="icon" href={`${base}favicon.svg`} type="image/svg+xml" />
    <link rel="icon" href={`${base}favicon-32.png`} sizes="32x32" type="image/png" />
    <link rel="icon" href={`${base}favicon-16.png`} sizes="16x16" type="image/png" />
    <link rel="apple-touch-icon" href={`${base}apple-touch-icon.png`} />
    <link rel="manifest" href={`${base}site.webmanifest`} />
    <meta name="theme-color" content="#6b2c37" />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
