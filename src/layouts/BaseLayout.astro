---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'Catálogo de vinos',
  description = 'Catálogo de vinos con búsqueda y filtros por bodega, denominación de origen y añada.',
} = Astro.props;
// public/ is served from the base root, so this resolves under /wine-catalogue/ in prod.
const favicon = `${import.meta.env.BASE_URL}favicon.svg`;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href={favicon} />
    <title>{title}</title>
    <meta name="description" content={description} />
  </head>
  <body>
    <slot />
  </body>
</html>
