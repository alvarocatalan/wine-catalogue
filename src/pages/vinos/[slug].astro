---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const vinos = await getCollection('vinos');
  return vinos.map((wine) => ({ params: { slug: wine.id }, props: { wine } }));
}

const { wine } = Astro.props;
const { nombre, bodega, denominacionOrigen, anada, foto, fotoAlt } = wine.data;
const { Content } = await render(wine);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`${nombre} — ${bodega}`}
  description={`${nombre} ${anada}, ${bodega} (${denominacionOrigen}).`}
>
  <main class="wrap detail">
    <a class="back" href={base}>← Catálogo</a>
    <h1>{nombre}</h1>
    <Image
      src={foto}
      alt={fotoAlt}
      onerror={`this.onerror=null;this.src='${base}placeholder.svg'`}
    />
    <dl>
      <dt>Bodega</dt><dd>{bodega}</dd>
      <dt>Denominación de Origen</dt><dd>{denominacionOrigen}</dd>
      <dt>Añada</dt><dd>{anada}</dd>
    </dl>
    <div class="notas"><Content /></div>
  </main>
</BaseLayout>
