---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

export async function getStaticPaths() {
  const vinos = await getCollection('vinos');
  return vinos.map((v) => ({ params: { slug: v.id }, props: { v } }));
}

const { v } = Astro.props;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{v.data.nombre}</title>
  </head>
  <body>
    <a href={import.meta.env.BASE_URL}>← Catálogo</a>
    <h1>{v.data.nombre}</h1>
    <Image src={v.data.foto} alt={v.data.fotoAlt} />
    <dl>
      <dt>Bodega</dt><dd>{v.data.bodega}</dd>
      <dt>Denominación de Origen</dt><dd>{v.data.denominacionOrigen}</dd>
      <dt>Añada</dt><dd>{v.data.anada}</dd>
    </dl>
  </body>
</html>
