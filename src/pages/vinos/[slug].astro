---
import { getCollection, render } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '../../layouts/BaseLayout.astro';
import TypeLabel from '../../components/TypeLabel.astro';

export async function getStaticPaths() {
  const vinos = await getCollection('vinos');
  return vinos.map((wine) => ({ params: { slug: wine.id }, props: { wine } }));
}

const { wine } = Astro.props;
const { nombre, bodega, denominacionOrigen, anada, tipo, foto, fotoAlt } = wine.data;
const { Content } = await render(wine);
const base = import.meta.env.BASE_URL;
---

<BaseLayout
  title={`${nombre} — ${bodega}`}
  description={`${nombre} ${anada}, ${bodega} (${denominacionOrigen}).`}
>
  <div class="detail-topbar">
    <a class="back" href={base}>← Volver al catálogo</a>
  </div>

  <main class="wrap detail">
    <div class="detail__grid">
      <div class="detail__media">
        <Image
          src={foto}
          alt={fotoAlt}
          widths={[320, 640]}
          sizes="(max-width: 760px) 80vw, 320px"
          onerror={`this.onerror=null;this.src='${base}placeholder.svg'`}
        />
      </div>

      <div class="detail__info">
        <TypeLabel tipo={tipo} variant="detail" />
        <h1 class="detail__name">{nombre}</h1>
        <p class="detail__bodega">{bodega}</p>

        <dl class="datatable">
          <div class="datatable__row"><dt>Bodega</dt><dd>{bodega}</dd></div>
          <div class="datatable__row">
            <dt>Denominación de Origen</dt><dd>{denominacionOrigen}</dd>
          </div>
          <div class="datatable__row"><dt>Añada</dt><dd>{anada}</dd></div>
        </dl>

        <h2 class="notas-title">Notas de cata</h2>
        <div class="notas"><Content /></div>
      </div>
    </div>
  </main>
</BaseLayout>
