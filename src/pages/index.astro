---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WineGrid from '../components/WineGrid.astro';
import CatalogueSearch from '../components/CatalogueSearch.tsx';
import { orderByNewest } from '../lib/order';

const wines = orderByNewest(await getCollection('vinos'));

// Build-time text search index consumed by the in-memory search island (T037).
// Embedded JSON — NOT Pagefind (research Decision 7). The island hydrates over it.
const searchIndex = wines.map((w) => ({
  slug: w.id,
  nombre: w.data.nombre,
  bodega: w.data.bodega,
  denominacionOrigen: w.data.denominacionOrigen,
  anada: w.data.anada,
}));
---

<BaseLayout title="Catálogo de vinos">
  <main class="wrap">
    <h1 class="site-title">Catálogo de vinos</h1>
    {wines.length > 0 && <CatalogueSearch client:load />}
    <WineGrid wines={wines} />
    <div id="no-results" class="empty" hidden role="status">
      <p>Sin resultados. Prueba con otro término o quita los filtros.</p>
    </div>
  </main>
  <script
    type="application/json"
    id="wine-search-index"
    set:html={JSON.stringify(searchIndex)}
  />
</BaseLayout>
