---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import WineGrid from '../components/WineGrid.astro';

const wines = (await getCollection('vinos')).sort(
  (a, b) => +new Date(b.data.createdAt) - +new Date(a.data.createdAt),
);

// Build-time text search index consumed by the in-memory search island (US3, T037).
// Embedded JSON — NOT Pagefind (research Decision 7).
const searchIndex = wines.map((w) => ({
  slug: w.id,
  nombre: w.data.nombre,
  bodega: w.data.bodega,
  denominacionOrigen: w.data.denominacionOrigen,
  anada: w.data.anada,
}));
---

<BaseLayout title="Catálogo de vinos">
  <main class="wrap">
    <h1 class="site-title">Catálogo de vinos</h1>
    <WineGrid wines={wines} />
  </main>
  <script
    type="application/json"
    id="wine-search-index"
    set:html={JSON.stringify(searchIndex)}
  />
</BaseLayout>
