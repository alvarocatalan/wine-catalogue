---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';

const vinos = await getCollection('vinos');

// Build-time text search index consumed by the in-memory search island (T037/T052).
// Emitted as embedded JSON — NOT Pagefind (research Decision 7).
const searchIndex = vinos.map((v) => ({
  slug: v.id,
  nombre: v.data.nombre,
  bodega: v.data.bodega,
  denominacionOrigen: v.data.denominacionOrigen,
  anada: v.data.anada,
}));
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Catálogo de vinos</title>
  </head>
  <body>
    <h1>Catálogo de vinos</h1>
    <ul>
      {vinos.map((v) => (
        <li>
          <a href={`${import.meta.env.BASE_URL}vinos/${v.id}/`}>
            <Image src={v.data.foto} alt={v.data.fotoAlt} />
            <span>{v.data.nombre} — {v.data.bodega} ({v.data.anada})</span>
          </a>
        </li>
      ))}
    </ul>

    <script
      type="application/json"
      id="wine-search-index"
      set:html={JSON.stringify(searchIndex)}
    />
  </body>
</html>
