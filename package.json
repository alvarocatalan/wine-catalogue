{
  "name": "wine-catalogue",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/validate-images.mjs",
    "build": "SKIP_KEYSTATIC=true astro build",
    "build:cms": "astro build",
    "preview": "SKIP_KEYSTATIC=true astro preview",
    "test": "vitest run",
    "test:island": "vitest run tests/component",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:dev": "playwright test --config playwright.dev.config.ts",
    "check": "astro check",
    "perf": "npm run build && lhci autorun",
    "lint": "astro check && eslint . && prettier --check .",
    "format": "prettier --write .",
    "validate:images": "node scripts/validate-images.mjs",
    "verify:static": "node scripts/verify-static.mjs",
    "gen:fixture": "node scripts/gen-fixture.mjs"
  },
  "dependencies": {
    "@astrojs/markdoc": "^0.15.11",
    "@astrojs/node": "^9.5.5",
    "@astrojs/preact": "^4.1.3",
    "@astrojs/react": "^4.4.2",
    "@keystatic/astro": "^5.2.0",
    "@keystatic/core": "^0.5.51",
    "@preact/signals": "^2.9.4",
    "astro": "^5.18.2",
    "preact": "^10.29.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/preact": "^3.2.4",
    "@types/node": "^26.1.1",
    "astro-eslint-parser": "^3.0.0",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-astro": "^3.0.1",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
  }
}
